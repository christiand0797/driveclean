# DriveClean Environment Variables
# Copy this file to .env and fill in the values
# See DEPLOY.md for step-by-step instructions

# Google OAuth credentials (required)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_real_secret_here

# OAuth callback URL (required)
# Local: http://localhost:3000/api/auth/callback
# Production: https://your-app.onrender.com/api/auth/callback
REDIRECT_URI=http://localhost:3000/api/auth/callback

# AES encryption key for session tokens (required)
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
# IMPORTANT: Keep this stable across restarts or all sessions will be invalidated
ENCRYPTION_KEY=generate_with_node_-e_"require('crypto').randomBytes(32).toString('hex')"

# Server port (optional, defaults to 3000)
PORT=3000

# Maximum files to scan (optional, defaults to 50000)
# Increase for very large drives, decrease for faster scans
SCAN_LIMIT=50000
